# Copy to /etc/nginx/sites-available/baggage-api, then:
#   sudo mkdir -p /var/www/html
#   sudo nginx -t && sudo systemctl reload nginx
#   sudo certbot --nginx -d api.seqrview.avagtpl.com
#
# This file is intentionally HTTP-only on port 80 so `nginx -t` passes before
# any TLS certs exist. Certbot will add listen 443 + ssl_certificate lines.
#
# After HTTPS works, you may change `location /` below from `proxy_pass` to:
#   return 301 https://$host$request_uri;
# so browsers use HTTPS only (optional; Certbot may already set this up).
#
# Zone: seqrview.avagtpl.com — dedicated API host (not seqrview.avagtpl.com).
# Prerequisites:
# - DNS A/AAAA: api.seqrview.avagtpl.com -> server's public IP
# - Backend: HOST=127.0.0.1 PORT=3040

server {
    listen 80;
    listen [::]:80;
    server_name api.seqrview.avagtpl.com;

    location /.well-known/acme-challenge/ {
        root /var/www/html;
    }

    client_max_body_size 10m;

    location / {
        proxy_pass http://127.0.0.1:3040;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Connection "";
        proxy_connect_timeout 60s;
        proxy_send_timeout 60s;
        proxy_read_timeout 60s;
    }
}
